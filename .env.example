# Tanya Docker configuration — copy to .env and fill in.
# `./setup docker` generates this for you; you only need to edit it manually
# if you want to change values without re-running the wizard.

# ── User ─────────────────────────────────────────────────────────────
USER_NAME=
USER_PHONE=not-shared
TELEGRAM_USERNAME=not-set
TELEGRAM_CHAT_ID=pending-pairing

# ── Required API keys ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# ── Feature flags (1 = on, 0 = off) ──────────────────────────────────
ENABLE_IMAGES=0
ENABLE_VOICE=0
ENABLE_WEB=0
ENABLE_CALLS=0

# ── Feature keys (only needed if corresponding flag is 1) ────────────
GOOGLE_API_KEY=
WEB_SEARCH_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=ulZgFXalzbrnPUGQGs0S
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=

# ── Runtime (don't edit unless you know why) ─────────────────────────
GATEWAY_TOKEN=
MAIN_MODEL=openai/gpt-5.4
MINI_MODEL=openai/gpt-5.4-mini

# ── Container ────────────────────────────────────────────────────────
# Port exposed on host for OpenClaw's local gateway (management UI).
# Tanya talks to Telegram outbound, so this is optional.
GATEWAY_PORT=18789
